{
  "name": "durango-mini",
  "version": "0.2.0",
  "description": "분산 존 서버 구조의 미니 듀랑고 — 5개 zone, 인공 latency 시뮬레이션",
  "main": "server/zone.js",
  "scripts": {
    "central": "node --experimental-sqlite server/central.js",
    "dispatcher": "node server/dispatcher.js",
    "marketplace": "node --experimental-sqlite server/marketplace.js",
    "start": "node scripts/launch-all.js",
    "start:drawn": "ENABLED_ZONES=nordan,europa,sahar,centaria,hindgang,sibara,jungwon_n,jungwon_s,bering,hanbando,nippon node scripts/launch-all.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
